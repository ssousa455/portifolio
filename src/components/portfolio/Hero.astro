---
import { readData } from '../../lib/readData';
const portfolio = readData('portfolio.json');
const hero = portfolio.hero;
---

<section style="background: var(--walker-dark, #0f172a); padding: 80px 0;">
  <div class="container-xl">
    <div class="row align-items-center">
      <div class="col-lg-7">
        <h1 style="font-family: var(--walker-font-heading, 'Inter', sans-serif); font-size: clamp(2rem, 5vw, 3rem); font-weight: 700; color: #fff; line-height: 1.2; margin-bottom: 1rem;">
          {hero.title.split('<br>').map((part: string, i: number) => (
            <span>{part}{i < hero.title.split('<br>').length - 1 ? <br /> : ''}</span>
          ))}
        </h1>
        <p style="font-size: 1.25rem; color: rgba(255,255,255,0.7); margin-bottom: 1.5rem;">{hero.subtitle}</p>
        <p style="color: rgba(255,255,255,0.6); font-size: 1.1rem; margin-bottom: 2rem; max-width: 600px;">{hero.description}</p>
        <div class="d-flex gap-3 flex-wrap">
          {hero.buttons.map((btn: { label: string; url: string; style: string }) => (
            <a href={btn.url} class={btn.style === 'primary' ? 'btn btn-primary btn-lg' : 'btn btn-outline-light btn-lg'} target={btn.url.startsWith('http') ? '_blank' : undefined} rel={btn.url.startsWith('http') ? 'noopener noreferrer' : undefined}>
              {btn.label}
            </a>
          ))}
        </div>
      </div>
      <div class="col-lg-5 text-center mt-4 mt-lg-0">
        <img src={hero.photoUrl} alt="Sérgio Sousa" style="width: 280px; height: 280px; border-radius: 50%; object-fit: cover; border: 4px solid var(--walker-primary, #3B82F6); box-shadow: 0 0 40px rgba(59,130,246,0.3);" />
      </div>
    </div>
  </div>
</section>
