---
import BaseLayout from '../layouts/BaseLayout.astro';
import Sidebar from '../components/Sidebar.astro';
import EmailInlineBanner from '../plugins/email-list/EmailInlineBanner.astro';
import AffiliateProducts from '../plugins/affiliates/AffiliateProducts.astro';
import PostSchemaPlugins from '../plugins/_slots/PostSchemaPlugins.astro';
import PostBottomPlugins from '../plugins/_slots/PostBottomPlugins.astro';
import PostAfterPlugins from '../plugins/_slots/PostAfterPlugins.astro';
import SocialShare from '../plugins/social-share/SocialShare.astro';
import { getCollection } from 'astro:content';
import { readData } from '../lib/readData';
import { postUrl } from '../lib/blogRoutes';
const authorsData = readData('authors.json', []);

const pluginsConfig = readData('pluginsConfig.json', {}) as any;
const inlineConfig = pluginsConfig?.emailList?.inline;
const inlineEnabled = inlineConfig?.enabled === true;
const inlinePosition = Number(inlineConfig?.position ?? 3);

export async function getStaticPaths() {
  const RESERVED = ['contato', 'sobre', 'privacidade', 'termos', 'blog', 'admin', 'api', 'categoria'];
  const siteConfig = (await import('../lib/readData')).readData('siteConfig.json');
  const prefix = siteConfig.blogPrefix ?? '';

  if (prefix !== '') return [];

  const posts = await getCollection('blog');
  return posts
    .filter(post => !RESERVED.includes(post.slug))
    .map((post) => ({
      params: { slug: post.slug },
      props: post,
    }));
}
const post = Astro.props;
const { Content } = await post.render();

const currentAuthor = authorsData.find((a: any) => a.id === post.data.author) || authorsData[0] || {
  name: 'Equipe',
  role: 'Redação',
  avatar: '',
  bio: ''
};

const categorySlug = post.data.category ? post.data.category.toLowerCase().replace(/[^a-z0-9]/g, '-') : '';
const siteConfig = readData('siteConfig.json', {}) as any;
const fullPostUrl = `${siteConfig.url || Astro.url.origin}${postUrl(post.slug)}`;
---

<BaseLayout title={post.data.title} description={post.data.description} image={post.data.heroImage} type="article">
  <PostSchemaPlugins
    title={post.data.title}
    description={post.data.description || ''}
    url={fullPostUrl}
    image={post.data.heroImage}
    datePublished={post.data.pubDate instanceof Date ? post.data.pubDate.toISOString() : post.data.pubDate}
    authorName={currentAuthor?.name}
    category={post.data.category}
  />

  <section class="max-w-6xl mx-auto px-4 py-10">
    <!-- Breadcrumb -->
    <nav class="text-sm text-gray-500 mb-6">
      <a href="/" class="hover:text-gray-700">Home</a>
      {post.data.category && (
        <>
          <span class="mx-2">/</span>
          <a href={`/categoria/${categorySlug}`} class="hover:text-gray-700">{post.data.category}</a>
        </>
      )}
      <span class="mx-2">/</span>
      <span class="text-gray-400 truncate">{post.data.title}</span>
    </nav>

    <div class="flex flex-col lg:flex-row gap-8">
      <!-- Main article -->
      <article class="flex-1 min-w-0">
        <!-- Post header -->
        <header class="mb-6">
          {post.data.category && (
            <a href={`/categoria/${categorySlug}`} class="category-badge">{post.data.category}</a>
          )}
          <h1 class="text-3xl font-bold mt-3 mb-4 leading-tight" style="font-family: var(--font-heading);">{post.data.title}</h1>
          <div class="flex items-center gap-3 text-sm text-gray-500">
            {currentAuthor.avatar ? (
              <img src={currentAuthor.avatar} alt={currentAuthor.name} class="w-8 h-8 rounded-full object-cover" />
            ) : (
              <div class="w-8 h-8 rounded-full bg-gray-200 flex items-center justify-center text-gray-500 font-bold text-sm">
                {currentAuthor.name.charAt(0)}
              </div>
            )}
            <span>{currentAuthor.name}</span>
            <span>·</span>
            <time>{post.data.pubDate.toLocaleDateString('pt-BR', { day: '2-digit', month: 'long', year: 'numeric' })}</time>
          </div>
        </header>

        <!-- Featured image -->
        {post.data.heroImage && (
          <img src={post.data.heroImage} alt={post.data.title} class="w-full rounded-xl mb-8 object-cover max-h-96" />
        )}

        <!-- Post content -->
        <div class="post-content">
          <Content />
        </div>

        <!-- Email inline banner -->
        {inlineEnabled && (
          <div id="email-inline-source" data-position={inlinePosition} style="display:none">
            <EmailInlineBanner />
          </div>
        )}

        <!-- Affiliate products -->
        <AffiliateProducts />

        <!-- Post bottom: tags + social share -->
        <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 mt-8 pt-6 border-t border-gray-200">
          <div>
            {post.data.category && (
              <a href={`/categoria/${categorySlug}`} class="category-badge">#{post.data.category}</a>
            )}
          </div>
          <PostBottomPlugins title={post.data.title} />
        </div>

        <!-- About author -->
        <div class="bg-white rounded-xl border border-gray-200 p-6 mt-8 flex gap-4">
          {currentAuthor.avatar ? (
            <img src={currentAuthor.avatar} alt={currentAuthor.name} class="w-16 h-16 rounded-full object-cover flex-shrink-0" />
          ) : (
            <div class="w-16 h-16 rounded-full bg-gray-100 flex items-center justify-center text-2xl font-bold text-gray-400 flex-shrink-0">
              {currentAuthor.name.charAt(0)}
            </div>
          )}
          <div>
            <h4 class="font-bold text-base" style="font-family: var(--font-heading);">{currentAuthor.name}</h4>
            {currentAuthor.role && <p class="text-xs mb-1" style="color: var(--color-primary);">{currentAuthor.role}</p>}
            {currentAuthor.bio && <p class="text-sm text-gray-600">{currentAuthor.bio}</p>}
            <div class="mt-2">
              <SocialShare title={post.data.title} context="author-box" />
            </div>
          </div>
        </div>

        <!-- Post after: related posts -->
        <div class="mt-8">
          <PostAfterPlugins
            currentSlug={post.slug}
            category={post.data.category || ''}
          />
        </div>

        <!-- Comment form -->
        <div class="bg-white rounded-xl border border-gray-200 p-6 mt-8">
          <h3 class="text-xl font-bold mb-4" style="font-family: var(--font-heading);">Deixe um Comentário</h3>
          <form id="comment-form" method="post" class="flex flex-col gap-4">
            <textarea name="InputComment" rows="4" placeholder="Seu comentário..." required
              class="w-full border border-gray-200 rounded-lg px-4 py-3 text-sm resize-none focus:outline-none focus:ring-2 focus:ring-[--color-primary]"></textarea>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <input type="text" name="InputName" placeholder="Seu nome" required
                class="border border-gray-200 rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-[--color-primary]" />
              <input type="email" name="InputEmail" placeholder="Seu e-mail" required
                class="border border-gray-200 rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-[--color-primary]" />
            </div>
            <div>
              <button type="submit" class="btn-primary">Enviar Comentário</button>
            </div>
          </form>
        </div>
      </article>

      <!-- Sidebar -->
      <aside class="lg:w-80 flex-shrink-0">
        <Sidebar />
      </aside>
    </div>
  </section>

  <script is:inline>
  (function() {
    var postContent = document.querySelector('.post-content');
    if (!postContent) return;
    var walker = document.createTreeWalker(postContent, NodeFilter.SHOW_TEXT, null);
    var node;
    while ((node = walker.nextNode())) {
      if (node.nodeValue && node.nodeValue.indexOf('\u00A0') !== -1) {
        node.nodeValue = node.nodeValue.replace(/\u00A0/g, ' ');
      }
    }
  })();
  </script>

  {inlineEnabled && (
    <script>
    (function() {
      const source = document.getElementById('email-inline-source');
      if (!source) return;
      const pos = Number((source as HTMLElement).dataset.position) || 3;
      const paragraphs = document.querySelectorAll('.post-content > p');
      const target = paragraphs[pos - 1] || paragraphs[paragraphs.length - 1];
      if (target) {
        target.insertAdjacentElement('afterend', source);
        source.style.display = 'block';
      }
    })();
    </script>
  )}

</BaseLayout>
