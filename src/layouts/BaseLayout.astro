---
import { readData } from '../lib/readData';
import { getCollection } from 'astro:content';
import HeadPlugins from '../plugins/_slots/HeadPlugins.astro';
import BodyEndPlugins from '../plugins/_slots/BodyEndPlugins.astro';

const siteConfig = readData('siteConfig.json');
const pluginsConfig = readData('pluginsConfig.json', {});
const gscVerificationTag = (pluginsConfig as any)?.searchConsole?.verificationTag?.trim() || '';

// Font mapping
const fontMap: Record<string, { heading: string; body: string; url: string }> = {
  inter:      { heading: 'Inter',            body: 'Roboto Mono',   url: 'family=Inter:wght@400;500;600;700&family=Roboto+Mono:wght@400;500' },
  outfit:     { heading: 'Outfit',           body: 'Inter',         url: 'family=Outfit:wght@400;500;600;700&family=Inter:wght@400;500' },
  roboto:     { heading: 'Roboto',           body: 'Open Sans',     url: 'family=Roboto:wght@400;500;700&family=Open+Sans:wght@400;600' },
  poppins:    { heading: 'Poppins',          body: 'Roboto',        url: 'family=Poppins:wght@400;500;600;700&family=Roboto:wght@400;500' },
  montserrat: { heading: 'Montserrat',       body: 'Merriweather',  url: 'family=Montserrat:wght@400;500;600;700&family=Merriweather:wght@400;700' },
  playfair:   { heading: 'Playfair Display', body: 'Source Sans 3', url: 'family=Playfair+Display:wght@400;500;600;700&family=Source+Sans+3:wght@400;600' },
  lora:       { heading: 'Lora',             body: 'Merriweather',  url: 'family=Lora:wght@400;500;600;700&family=Merriweather:wght@400;700' },
};
const selectedFont = fontMap[siteConfig.theme?.font || 'poppins'] || fontMap.poppins;

const primaryColor = siteConfig.theme?.primary || '#FE4F70';
const accentColor = siteConfig.theme?.accent || '#FFA387';
const darkColor = siteConfig.theme?.dark || '#203656';
const categoriesData = readData('categories.json', []);
const menuItems: any[] = readData('menu.json', { items: [] }).items || [];

const posts = await getCollection('blog');
const categoriesFromPosts = [...new Set(posts.map(p => p.data.category).filter(Boolean))];
const finalCategoriesData = Array.isArray(categoriesData) ? categoriesData : [];
const allCategories = finalCategoriesData.length > 0 ? finalCategoriesData : categoriesFromPosts;

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
  bodyClass?: string;
}

const {
  title = siteConfig.name,
  description = siteConfig.description,
  image = '',
  type = 'website',
  bodyClass = '',
} = Astro.props;

const formattedTitle = title === siteConfig.name ? title : `${title} | ${siteConfig.name}`;
const siteUrl = siteConfig.url || Astro.url.origin;
const socialImage = image?.startsWith('http') ? image : image ? new URL(image, siteUrl).toString() : '';
---

<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta http-equiv="Content-Type" content="text/html; charset=UTF-8">
  <title>{formattedTitle}</title>
  <meta name="description" content={description}>
  <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1">
  <link rel="icon" href={siteConfig.favicon || '/favicon.svg'} />

  <!-- Google Search Console verification -->
  {gscVerificationTag && (
    gscVerificationTag.startsWith('<')
      ? <Fragment set:html={gscVerificationTag} />
      : <meta name="google-site-verification" content={gscVerificationTag} />
  )}

  <!-- Open Graph -->
  <meta property="og:type" content={type} />
  <meta property="og:title" content={formattedTitle} />
  <meta property="og:description" content={description} />
  {socialImage && <meta property="og:image" content={socialImage} />}
  <meta property="og:url" content={Astro.url} />

  <!-- STYLES via CDN -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/simple-line-icons/2.5.5/css/simple-line-icons.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/slick-carousel@1.8.1/slick/slick.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/slick-carousel@1.8.1/slick/slick-theme.css">
  <!-- Walker theme -->
  <link rel="stylesheet" href="/css/style.css">
  <!-- Google Fonts (dynamic) -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="stylesheet" href={`https://fonts.googleapis.com/css2?${selectedFont.url}&display=swap`}>
  <!-- Dynamic theme colors from CMS -->
  <Fragment set:html={`<style>
    :root {
      --walker-primary: ${primaryColor};
      --walker-accent: ${accentColor};
      --walker-dark: ${darkColor};
      --walker-font-heading: "${selectedFont.heading}", sans-serif;
      --walker-font-body: "${selectedFont.body}", sans-serif;
    }
  </style>`} />
  <!-- Head plugins: GA, Meta Pixel, AdSense -->
  <HeadPlugins />
</head>

<body class={bodyClass}>

<!-- preloader -->
<div id="preloader">
  <div class="book">
    <div class="inner">
      <div class="left"></div>
      <div class="middle"></div>
      <div class="right"></div>
    </div>
    <ul>
      <li></li><li></li><li></li><li></li><li></li><li></li>
      <li></li><li></li><li></li><li></li><li></li><li></li>
      <li></li><li></li><li></li><li></li><li></li><li></li>
    </ul>
  </div>
</div>

<!-- site wrapper -->
<div class="site-wrapper">

  <div class="main-overlay"></div>

  <!-- header -->
  <header class="header-default">
    <nav class="navbar navbar-expand-lg">
      <div class="container-xl">
        <!-- logo -->
        <a class="navbar-brand" href="/">
          {siteConfig.logo ? (
            <img src={siteConfig.logo} alt={siteConfig.name} />
          ) : (
            <span style="font-family: var(--walker-font-heading); font-weight: 700; font-size: 1.5rem; color: var(--walker-dark);">{siteConfig.name}</span>
          )}
        </a>

        <div class="collapse navbar-collapse">
          <ul class="navbar-nav mr-auto">
            {menuItems.map((item: any) => (
              item.showCategories ? (
                <li class="nav-item dropdown">
                  <a class="nav-link dropdown-toggle" href={item.href}>{item.label}</a>
                  <ul class="dropdown-menu">
                    <li><a class="dropdown-item" href={item.href}>Todos os Artigos</a></li>
                    {allCategories.map(cat => (
                      <li>
                        <a class="dropdown-item" href={`/categoria/${cat.toLowerCase().replace(/[^a-z0-9]/g, '-')}`}>{cat}</a>
                      </li>
                    ))}
                  </ul>
                </li>
              ) : (
                <li class="nav-item">
                  <a class="nav-link" href={item.href}>{item.label}</a>
                </li>
              )
            ))}
          </ul>
        </div>

        <!-- header right -->
        <div class="header-right">
          <ul class="social-icons list-unstyled list-inline mb-0">
            {siteConfig.social?.facebook && (
              <li class="list-inline-item"><a href={siteConfig.social.facebook} target="_blank" rel="noopener"><i class="fab fa-facebook-f"></i></a></li>
            )}
            {siteConfig.social?.twitter && (
              <li class="list-inline-item"><a href={siteConfig.social.twitter} target="_blank" rel="noopener"><i class="fab fa-twitter"></i></a></li>
            )}
            {siteConfig.social?.instagram && (
              <li class="list-inline-item"><a href={siteConfig.social.instagram} target="_blank" rel="noopener"><i class="fab fa-instagram"></i></a></li>
            )}
            {siteConfig.social?.pinterest && (
              <li class="list-inline-item"><a href={siteConfig.social.pinterest} target="_blank" rel="noopener"><i class="fab fa-pinterest"></i></a></li>
            )}
            {siteConfig.social?.youtube && (
              <li class="list-inline-item"><a href={siteConfig.social.youtube} target="_blank" rel="noopener"><i class="fab fa-youtube"></i></a></li>
            )}
          </ul>
          <div class="header-buttons">
            <button class="search icon-button">
              <i class="icon-magnifier"></i>
            </button>
            <button class="burger-menu icon-button">
              <span class="burger-icon"></span>
            </button>
          </div>
        </div>
      </div>
    </nav>
  </header>

  <!-- PAGE CONTENT -->
  <slot />

  <!-- instagram feed -->
  {siteConfig.social?.instagram && (
    <div class="instagram">
      <div class="container-xl">
        <a href={siteConfig.social.instagram} class="btn btn-default btn-instagram" target="_blank" rel="noopener">
          @{siteConfig.social.instagram.replace('https://instagram.com/', '').replace('https://www.instagram.com/', '')} no Instagram
        </a>
        <div class="instagram-feed d-flex flex-wrap">
          <div class="insta-item col-sm-2 col-6 col-md-2"><a href={siteConfig.social.instagram}><img src="https://picsum.photos/seed/insta1/300/300" alt="instagram" /></a></div>
          <div class="insta-item col-sm-2 col-6 col-md-2"><a href={siteConfig.social.instagram}><img src="https://picsum.photos/seed/insta2/300/300" alt="instagram" /></a></div>
          <div class="insta-item col-sm-2 col-6 col-md-2"><a href={siteConfig.social.instagram}><img src="https://picsum.photos/seed/insta3/300/300" alt="instagram" /></a></div>
          <div class="insta-item col-sm-2 col-6 col-md-2"><a href={siteConfig.social.instagram}><img src="https://picsum.photos/seed/insta4/300/300" alt="instagram" /></a></div>
          <div class="insta-item col-sm-2 col-6 col-md-2"><a href={siteConfig.social.instagram}><img src="https://picsum.photos/seed/insta5/300/300" alt="instagram" /></a></div>
          <div class="insta-item col-sm-2 col-6 col-md-2"><a href={siteConfig.social.instagram}><img src="https://picsum.photos/seed/insta6/300/300" alt="instagram" /></a></div>
        </div>
      </div>
    </div>
  )}

  <!-- footer -->
  <footer>
    <div class="container-xl">
      <div class="footer-inner">
        <div class="row d-flex align-items-center gy-4">
          <div class="col-md-4">
            <span class="copyright">© {new Date().getFullYear()} {siteConfig.name}.</span>
          </div>
          <div class="col-md-4 text-center">
            <ul class="social-icons list-unstyled list-inline mb-0">
              {siteConfig.social?.facebook && (<li class="list-inline-item"><a href={siteConfig.social.facebook} target="_blank" rel="noopener"><i class="fab fa-facebook-f"></i></a></li>)}
              {siteConfig.social?.twitter && (<li class="list-inline-item"><a href={siteConfig.social.twitter} target="_blank" rel="noopener"><i class="fab fa-twitter"></i></a></li>)}
              {siteConfig.social?.instagram && (<li class="list-inline-item"><a href={siteConfig.social.instagram} target="_blank" rel="noopener"><i class="fab fa-instagram"></i></a></li>)}
              {siteConfig.social?.pinterest && (<li class="list-inline-item"><a href={siteConfig.social.pinterest} target="_blank" rel="noopener"><i class="fab fa-pinterest"></i></a></li>)}
              {siteConfig.social?.youtube && (<li class="list-inline-item"><a href={siteConfig.social.youtube} target="_blank" rel="noopener"><i class="fab fa-youtube"></i></a></li>)}
            </ul>
          </div>
          <div class="col-md-4">
            <a href="#" id="return-to-top" class="float-md-end"><i class="icon-arrow-up"></i>Voltar ao Topo</a>
          </div>
        </div>
      </div>
    </div>
  </footer>

</div><!-- end site wrapper -->

<!-- search popup -->
<div class="search-popup">
  <button type="button" class="btn-close" aria-label="Close"></button>
  <div class="search-content">
    <div class="text-center">
      <h3 class="mb-4 mt-0">Pressione ESC para fechar</h3>
    </div>
    <form class="d-flex search-form" action="/blog">
      <input class="form-control me-2" type="search" name="q" placeholder="Buscar e pressione Enter ..." aria-label="Search">
      <button class="btn btn-default btn-lg" type="submit"><i class="icon-magnifier"></i></button>
    </form>
  </div>
</div>

<!-- canvas menu -->
<div class="canvas-menu d-flex align-items-end flex-column">
  <button type="button" class="btn-close" aria-label="Close"></button>
  <div class="logo">
    {siteConfig.logo ? (
      <img src={siteConfig.logo} alt={siteConfig.name} />
    ) : (
      <span style="font-family: var(--walker-font-heading); font-weight: 700; font-size: 1.5rem; color: var(--walker-dark);">{siteConfig.name}</span>
    )}
  </div>
  <nav>
    <ul class="vertical-menu">
      {menuItems.map((item: any) => (
        item.showCategories ? (
          <li>
            <a href={item.href}>{item.label}</a>
            <ul class="submenu">
              {allCategories.map(cat => (
                <li><a href={`/categoria/${cat.toLowerCase().replace(/[^a-z0-9]/g, '-')}`}>{cat}</a></li>
              ))}
            </ul>
          </li>
        ) : (
          <li><a href={item.href}>{item.label}</a></li>
        )
      ))}
    </ul>
  </nav>
  <ul class="social-icons list-unstyled list-inline">
    {siteConfig.social?.facebook && (<li class="list-inline-item"><a href={siteConfig.social.facebook} target="_blank" rel="noopener"><i class="fab fa-facebook-f"></i></a></li>)}
    {siteConfig.social?.twitter && (<li class="list-inline-item"><a href={siteConfig.social.twitter} target="_blank" rel="noopener"><i class="fab fa-twitter"></i></a></li>)}
    {siteConfig.social?.instagram && (<li class="list-inline-item"><a href={siteConfig.social.instagram} target="_blank" rel="noopener"><i class="fab fa-instagram"></i></a></li>)}
  </ul>
</div>

<!-- Body-end plugins: EmailPopup, CookieConsent -->
<BodyEndPlugins />

<!-- SCRIPTS -->
<script is:inline src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
<script is:inline src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script is:inline src="https://cdn.jsdelivr.net/npm/slick-carousel@1.8.1/slick/slick.min.js"></script>
<script is:inline src="/js/jquery.sticky-sidebar.min.js"></script>
<script is:inline src="/js/custom.js"></script>

</body>
</html>
